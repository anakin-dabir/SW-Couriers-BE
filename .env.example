# ──────────────────────────────────────────────
# SW Couriers Backend — Environment Variables
# ──────────────────────────────────────────────
# Copy to a local env file (both are loaded by the app when present) and fill in real values:
#   cp .env.example .env.local
#   cp .env.example .env
#
# NEVER commit .env.local or any file containing secrets.
# ──────────────────────────────────────────────

# ── App ──────────────────────────────────────
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO

# ── API ──────────────────────────────────────
API_PREFIX=/api

# ── Database (async driver required; match docker-compose: swcouriers/swcouriers_local) ─────────
# Host → Docker Postgres: use port 5433 (see docker-compose POSTGRES_PORT). Inside compose, api gets DATABASE_URL from compose.
DATABASE_URL=
DATABASE_ECHO=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# ── Redis (docker-compose maps 6380:6379; use 6380 when app runs on host) ──
REDIS_URL=redis://localhost:6380/0

# ── CORS ─────────────────────────────────────
# Must include every browser origin that calls this API (admin app, B2B portal, B2C app, warehouse, etc.).
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,Accept,Origin,X-API-Key,X-Client-Type,X-Password-Reset-Token,X-Invite-Token

# ── Auth cookies (use samesite=none for cross-domain API vs portal) ──
# Staging/production: MUST be `none` when the admin UI and API are on different origins
# (e.g. *.workers.dev + *.shiftopus.co.uk). Safari blocks unpartitioned third-party cookies.
COOKIE_SAMESITE=none

# ── Email & web portal base URLs ───────────────────────────────────────────
# Used when building links inside transactional emails (invite, verify-email, shared documents, driver onboarding).
#
# Per-role invite / verify-email: the API picks LINK_BASE_URL_<CLIENT_TYPE> from the user's role (see app/common/enums/user.py).
# Those settings default to localhost in code — setting only VERIFICATION_LINK_BASE_URL is NOT enough for B2B, because
# LINK_BASE_URL_CUSTOMER_B2B takes precedence whenever it is non-empty (including the default localhost value).
#
# Staging/production checklist:
#   - Set LINK_BASE_URL_CUSTOMER_B2B to your B2B portal origin (account owner verify + accept-invite emails).
#   - Set FRONTEND_BASE_URL if you send shared-document emails (path /shared-doc/<token> is appended).
#   - Set VERIFICATION_LINK_BASE_URL as a fallback when a per-type LINK_BASE_URL_* is left empty.
#   - Set other LINK_BASE_URL_* for each deployed client app that receives invite or verification mail.
#   - Arq workers that send mail must use the same values as the API process.
#
# Local dev (Vite ports match app/core/config.py defaults):
FRONTEND_BASE_URL=http://localhost:3000
VERIFICATION_LINK_BASE_URL=https://sw-couriers-admin-dev.shiftopus.workers.dev
EMAIL_LINK_ALLOWED_APP_SCHEMES=swcouriers
LINK_BASE_URL_ADMIN=http://localhost:5173
LINK_BASE_URL_CUSTOMER_B2B=http://localhost:5174
LINK_BASE_URL_CUSTOMER_B2C=http://localhost:5175
LINK_BASE_URL_WAREHOUSE=http://localhost:5176
# Driver: app deep link or universal-link HTTPS origin (no trailing slash).
LINK_BASE_URL_DRIVER=swcouriers://
DRIVER_ACTIVATION_INVITE_EXPIRE_DAYS=7
DRIVER_ACTIVATION_RESEND_MAX_PER_HOUR=5

# Staging / production — replace hostnames; uncomment and copy above, or override in your secrets manager:
# FRONTEND_BASE_URL=https://portal.staging.example.com
# VERIFICATION_LINK_BASE_URL=https://b2b.staging.example.com
# LINK_BASE_URL_ADMIN=https://admin.staging.example.com
# LINK_BASE_URL_CUSTOMER_B2B=https://b2b.staging.example.com
# LINK_BASE_URL_CUSTOMER_B2C=https://app.staging.example.com
# LINK_BASE_URL_WAREHOUSE=https://warehouse.staging.example.com
# LINK_BASE_URL_DRIVER=https://driver-invite.staging.example.com
# CORS_ORIGINS=https://admin.staging.example.com,https://b2b.staging.example.com,https://app.staging.example.com,https://warehouse.staging.example.com

# ── JWT ──────────────────────────────────────
JWT_SECRET_KEY=CHANGE-ME-generate-with-openssl-rand-hex-64
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_REFRESH_SECRET_KEY=CHANGE-ME-generate-with-openssl-rand-hex-64
# Dedicated secret for email verification tokens. When empty, falls back to JWT_SECRET_KEY
# (not recommended for production).
JWT_EMAIL_VERIFICATION_SECRET_KEY=CHANGE-ME-generate-with-openssl-rand-hex-64

# ── Braintree (Payment Processing) ──────────
BRAINTREE_MERCHANT_ID=
BRAINTREE_PUBLIC_KEY=
BRAINTREE_PRIVATE_KEY=
BRAINTREE_ENVIRONMENT=sandbox

# ── Cloudflare R2 (S3-compatible storage) ───
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=sw-couriers
R2_ENDPOINT_URL=

# ── Cloudflare Images (private hosted images) ─
# Used for driver profile photos and other non-sensitive images.
# All uploads are marked as requiring signed URLs at the account level.
CF_IMAGES_ACCOUNT_ID=
CF_IMAGES_API_TOKEN=
CF_IMAGES_BASE_URL= # optional override, usually leave empty

# ── Twilio (SMS) ─────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Email (Gmail SMTP) ──────────────────────
# For Gmail: enable 2FA, then create an App Password at https://myaccount.google.com/apppasswords
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-gmail@gmail.com
SMTP_PASSWORD=your-16-char-app-password
EMAIL_FROM_ADDRESS=your-gmail@gmail.com
EMAIL_FROM_NAME=SW Couriers
EMAIL_LOGO_URL=
SUPPORT_EMAIL=support@swcouriers.com
FINANCE_TEAM_EMAIL=finance@example.com

# ── Creditsafe Connect API (Credit Assessment) ──
# Sandbox: https://connect.sandbox.creditsafe.com/v1
# Production: https://connect.creditsafe.com/v1
CREDITSAFE_API_URL=
CREDITSAFE_USERNAME=
CREDITSAFE_PASSWORD=

# ── Ideal Postcodes (UK Address Lookup) ──────
IDEAL_POSTCODES_API_KEY=

# ── QuickBooks (Accounting Sync) ──────────────
# Sandbox setup:
# 1) Create Intuit app (QuickBooks Online + Payments)
# 2) Add redirect URI in Intuit portal to match QUICKBOOKS_REDIRECT_URI exactly
# 3) Use sandbox company for development/testing
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_ENV=sandbox
QUICKBOOKS_REDIRECT_URI=http://<your-domain>:8000/api/v1/integrations/quickbooks/callback
QUICKBOOKS_OAUTH_SUCCESS_URL=http://localhost:5173/settings/integrations/quickbooks
QUICKBOOKS_OAUTH_ERROR_URL=http://localhost:5173/settings/integrations/quickbooks
QUICKBOOKS_OAUTH_REDIRECT_ALLOWED_HOSTS=localhost,swdev.shiftopus.co.uk,shiftopus.co.uk,shiftopus.workers.dev

DRIVER_APP_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.courier.sw_couriers_driver_app
DRIVER_APP_APP_STORE_URL=https://apps.apple.com/app/id0000000000
QUICKBOOKS_SCOPES=com.intuit.quickbooks.accounting
# Optional override; usually keep empty and let env mode decide API base URL
QUICKBOOKS_API_BASE_URL=
# Required to encrypt OAuth tokens at rest (generate a strong random secret)
QUICKBOOKS_ENCRYPTION_KEY=CHANGE-ME-generate-with-openssl-rand-hex-64
# Webhook token is optional until webhook ingestion is enabled
QUICKBOOKS_WEBHOOK_VERIFIER_TOKEN=
QUICKBOOKS_CONNECT_TIMEOUT_MS=3000
QUICKBOOKS_READ_TIMEOUT_MS=10000
QUICKBOOKS_REFRESH_LEAD_SECONDS=600
QUICKBOOKS_REFRESH_SAFETY_MAX_AGE_SECONDS=86400 

# ── Sentry (Error Tracking) ─────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Swagger/ReDoc (HTTP Basic auth) ─────────
# Single user. Empty = docs return 401.
DOCS_USER=admin
DOCS_PASSWORD=your-secret-password

# ── OSRM (Self-hosted Routing Engine) ───────
OSRM_BASE_URL=http://localhost:5000


# ── Rate limiting (SlowAPI / Redis) ─────────
# Defaults are safe for local dev; override per-environment as needed.
# Format: "<count>/<period>", e.g. "300/minute", "10/minute", "100/hour"
RATE_LIMIT_DEFAULT=300/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_DRIVERS_WRITE=60/minute
RATE_LIMIT_DRIVERS_READ=120/minute
RATE_LIMIT_SUSPENSION_RULES_WRITE=5/minute
RATE_LIMIT_SUSPENSION_RULES_READ=60/minute
RATE_LIMIT_SERVICE_TIER_WRITE=5/minute
RATE_LIMIT_SERVICE_TIER_READ=60/minute
RATE_LIMIT_SHARED_DOC_PASSWORD=5/minute
RATE_LIMIT_DOC_OTP_VERIFY=5/minute
RATE_LIMIT_QUICKBOOKS_SYNC=10/minute
RATE_LIMIT_QUICKBOOKS_RESYNC=5/minute
RATE_LIMIT_QUICKBOOKS_RECONCILE=3/minute
RATE_LIMIT_QUICKBOOKS_CALLBACK=10/minute
RATE_LIMIT_QUICKBOOKS_CALLBACK_DUPLICATE=3/minute
QUICKBOOKS_ORG_QUEUE_MAX_PENDING=500
